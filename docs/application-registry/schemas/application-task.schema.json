{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "application-task.schema.json",
  "title": "Application Registry Task",
  "type": "object",
  "required": ["task_id", "task_type", "title", "status", "priority", "source", "created_at", "updated_at", "schema_version"],
  "additionalProperties": true,
  "properties": {
    "task_id": { "type": "string" },
    "application_id": { "type": ["string", "null"] },
    "contact_id": { "type": ["string", "null"] },
    "task_type": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "due_at": { "type": ["string", "null"] },
    "completed_at": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["open", "completed", "cancelled", "overdue"] },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
    "source": { "type": "string" },
    "recurrence": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "schema_version": { "type": "string" }
  }
}

