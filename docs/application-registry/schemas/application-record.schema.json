{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "application-record.schema.json",
  "title": "Application Registry Record",
  "type": "object",
  "required": ["application_id", "schema_version", "created_at", "updated_at", "company_name", "company_slug", "role_title", "current_stage", "current_status", "active", "priority", "product_os_modules", "manual_override_ids", "response_received", "interview_count", "offer_received", "owner", "last_activity_at", "tags", "confidentiality", "contains_personal_data", "safe_to_commit"],
  "additionalProperties": true,
  "properties": {
    "application_id": { "type": "string" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "company_name": { "type": "string" },
    "company_slug": { "type": "string" },
    "role_title": { "type": "string" },
    "role_level": { "type": ["string", "null"] },
    "department": { "type": ["string", "null"] },
    "employment_type": { "type": ["string", "null"] },
    "work_mode": { "type": ["string", "null"] },
    "location": { "type": ["string", "null"] },
    "country": { "type": ["string", "null"] },
    "relocation_required": { "type": ["boolean", "null"] },
    "visa_sponsorship_status": { "type": ["string", "null"] },
    "job_url": { "type": ["string", "null"] },
    "application_source": { "type": ["string", "null"] },
    "referral_source": { "type": ["string", "null"] },
    "job_posting_id": { "type": ["string", "null"] },
    "job_discovered_at": { "type": ["string", "null"] },
    "job_closing_date": { "type": ["string", "null"] },
    "application_date": { "type": ["string", "null"] },
    "current_stage": { "type": "string" },
    "current_status": { "type": "string" },
    "active": { "type": "boolean" },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
    "fit_score": { "type": ["number", "null"] },
    "application_channel": { "type": ["string", "null"] },
    "jd_snapshot_id": { "type": ["string", "null"] },
    "jd_path": { "type": ["string", "null"] },
    "jd_hash": { "type": ["string", "null"] },
    "resume_snapshot_id": { "type": ["string", "null"] },
    "resume_plan_path": { "type": ["string", "null"] },
    "narrative_output_path": { "type": ["string", "null"] },
    "docx_path": { "type": ["string", "null"] },
    "pdf_path": { "type": ["string", "null"] },
    "export_commit_hash": { "type": ["string", "null"] },
    "resume_version": { "type": ["string", "null"] },
    "role_pack": { "type": ["string", "null"] },
    "product_os_modules": { "type": "array", "items": { "type": "string" } },
    "manual_override_ids": { "type": "array", "items": { "type": "string" } },
    "response_received": { "type": "boolean" },
    "response_date": { "type": ["string", "null"] },
    "interview_count": { "type": "integer", "minimum": 0 },
    "final_outcome": { "type": ["string", "null"] },
    "rejection_stage": { "type": ["string", "null"] },
    "rejection_reason": { "type": ["string", "null"] },
    "offer_received": { "type": "boolean" },
    "offer_id": { "type": ["string", "null"] },
    "withdrawal_reason": { "type": ["string", "null"] },
    "owner": { "type": "string" },
    "next_action": { "type": ["string", "null"] },
    "next_action_due_at": { "type": ["string", "null"] },
    "follow_up_status": { "type": ["string", "null"] },
    "last_contact_at": { "type": ["string", "null"] },
    "last_activity_at": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes_summary": { "type": ["string", "null"] },
    "confidentiality": { "type": "string", "enum": ["private", "sanitized", "public-fixture"] },
    "contains_personal_data": { "type": "boolean" },
    "safe_to_commit": { "type": "boolean" }
  }
}

