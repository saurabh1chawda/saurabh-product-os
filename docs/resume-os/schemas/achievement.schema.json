{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:resume-os:schema:achievement",
  "title": "Resume OS Achievement",
  "type": "object",
  "required": [
    "id",
    "company",
    "role",
    "date",
    "category",
    "business_problem",
    "action",
    "outcome",
    "metric",
    "verification_status",
    "evidence_sources",
    "skills_demonstrated",
    "applicable_role_archetypes",
    "related_product_os_assets",
    "related_github_repository",
    "related_portfolio_url",
    "confidence_level",
    "importance_score",
    "evidence_strength",
    "confidence_status",
    "keyword_tags",
    "competency_tags",
    "domain_tags",
    "archetype_scores",
    "seniority_signal",
    "recruiter_value",
    "hiring_manager_value",
    "ats_value",
    "technical_depth",
    "leadership_depth",
    "business_impact_strength",
    "recency_score",
    "uniqueness_score",
    "interview_defensibility",
    "confidentiality_status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{3}-[A-Z]{2,3}-[0-9]{3}$"
    },
    "company": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "business_problem": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "metric": {
      "type": "object"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "reference_verified",
        "product_os_verified",
        "needs_review"
      ]
    },
    "evidence_sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "skills_demonstrated": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "applicable_role_archetypes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "related_product_os_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_github_repository": {
      "type": [
        "string",
        "null"
      ]
    },
    "related_portfolio_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "importance_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "evidence_strength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_status": {
      "type": "string",
      "enum": [
        "verified",
        "verified-public",
        "evidence-partial",
        "self-reported",
        "simulation",
        "prototype",
        "case-study",
        "conceptual"
      ]
    },
    "keyword_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "competency_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "archetype_scores": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      }
    },
    "seniority_signal": {
      "type": "string"
    },
    "recruiter_value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "hiring_manager_value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "ats_value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "technical_depth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "leadership_depth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "business_impact_strength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "recency_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "uniqueness_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "interview_defensibility": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidentiality_status": {
      "type": "string",
      "enum": [
        "resume_safe",
        "public_safe",
        "internal_only",
        "needs_review"
      ]
    }
  },
  "additionalProperties": false
}
