{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:resume-os:schema:jd-intelligence-output",
  "title": "Resume OS JD Intelligence Output",
  "type": "object",
  "required": [
    "jd_metadata",
    "normalized_role",
    "company_context",
    "primary_archetype",
    "secondary_archetypes",
    "archetype_scores",
    "competencies",
    "keywords",
    "hidden_signals",
    "ranked_achievements",
    "ranked_bullets",
    "recommended_headline",
    "recommended_summary",
    "recommended_skills",
    "recommended_project",
    "recommended_product_os_asset",
    "experience_plan",
    "gaps",
    "risks",
    "evidence_coverage",
    "ats_coverage",
    "confidence",
    "human_review_items",
    "final_recommendation"
  ],
  "properties": {
    "jd_metadata": {
      "type": "object",
      "required": ["jd_id", "source", "captured_at"],
      "properties": {
        "jd_id": { "type": "string" },
        "source": { "type": "string" },
        "source_url": { "type": ["string", "null"] },
        "captured_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "normalized_role": {
      "type": "object",
      "required": ["role_title", "normalized_role_title"],
      "additionalProperties": true
    },
    "company_context": {
      "type": "object",
      "additionalProperties": true
    },
    "primary_archetype": {
      "type": "object",
      "required": ["name", "score", "confidence", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "secondary_archetypes": {
      "type": "array",
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "score"],
        "properties": {
          "name": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "archetype_scores": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "competencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourcedSignal" }
    },
    "keywords": {
      "type": "array",
      "items": { "$ref": "#/$defs/keyword" }
    },
    "hidden_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/hiddenSignal" }
    },
    "ranked_achievements": {
      "type": "array",
      "items": { "$ref": "#/$defs/rankedEvidence" }
    },
    "ranked_bullets": {
      "type": "array",
      "items": { "$ref": "#/$defs/rankedBullet" }
    },
    "recommended_headline": { "$ref": "#/$defs/recommendation" },
    "recommended_summary": { "$ref": "#/$defs/recommendation" },
    "recommended_skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation" }
    },
    "recommended_project": { "$ref": "#/$defs/nullableRecommendation" },
    "recommended_product_os_asset": { "$ref": "#/$defs/nullableRecommendation" },
    "experience_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "recommended_bullet_ids"],
        "properties": {
          "role": { "type": "string" },
          "recommended_bullet_ids": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/risk" }
    },
    "evidence_coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "ats_coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "confidence": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "human_review_items": {
      "type": "array",
      "items": { "type": "string" }
    },
    "final_recommendation": {
      "type": "string",
      "enum": [
        "Strong Apply",
        "Apply",
        "Apply With Mitigation",
        "Low Priority",
        "Do Not Apply"
      ]
    }
  },
  "$defs": {
    "sourcedSignal": {
      "type": "object",
      "required": ["label", "source_phrases", "priority"],
      "properties": {
        "label": { "type": "string" },
        "source_phrases": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "string", "enum": ["required", "preferred", "supporting"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "keyword": {
      "type": "object",
      "required": ["keyword", "class", "source_section", "evidence_status"],
      "properties": {
        "keyword": { "type": "string" },
        "normalized_keyword": { "type": "string" },
        "class": {
          "type": "string",
          "enum": ["must_cover", "strongly_recommended", "supporting", "optional", "boilerplate", "dangerous_without_evidence"]
        },
        "source_section": { "type": "string" },
        "evidence_status": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hiddenSignal": {
      "type": "object",
      "required": ["signal", "supporting_phrases", "confidence", "explanation"],
      "properties": {
        "signal": { "type": "string" },
        "supporting_phrases": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "explanation": { "type": "string" },
        "resume_implication": { "type": "string" },
        "interview_implication": { "type": "string" },
        "evidence_gap": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "rankedEvidence": {
      "type": "object",
      "required": ["achievement_id", "score", "reasons", "penalties"],
      "properties": {
        "achievement_id": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "penalties": { "type": "array", "items": { "type": "string" } },
        "product_os_links": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "rankedBullet": {
      "type": "object",
      "required": ["bullet_id", "achievement_id", "source_file", "score"],
      "properties": {
        "bullet_id": { "type": "string" },
        "achievement_id": { "type": "string" },
        "source_file": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "duplicate_risk": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": ["recommended_component", "reason", "evidence_ids", "confidence"],
      "properties": {
        "recommended_component": { "type": "string" },
        "alternative": { "type": ["string", "null"] },
        "reason": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "jd_signals_addressed": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "risks": { "type": "array", "items": { "type": "string" } },
        "human_review_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "nullableRecommendation": {
      "oneOf": [
        { "$ref": "#/$defs/recommendation" },
        { "type": "null" }
      ]
    },
    "gap": {
      "type": "object",
      "required": ["severity", "gap", "jd_source_phrase", "current_evidence", "resume_mitigation"],
      "properties": {
        "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "gap": { "type": "string" },
        "jd_source_phrase": { "type": "string" },
        "current_evidence": { "type": "string" },
        "gap_explanation": { "type": "string" },
        "resume_mitigation": { "type": "string" },
        "product_os_mitigation": { "type": "string" },
        "interview_mitigation": { "type": "string" },
        "cannot_mitigate_honestly": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "required": ["severity", "risk", "mitigation"],
      "properties": {
        "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "risk": { "type": "string" },
        "mitigation": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
